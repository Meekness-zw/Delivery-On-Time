# ==============================
# Supabase Configuration
# ==============================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ==============================
# Dexatel (send OTP codes via SMS)
# ==============================
# Get your API key from: https://app.dexatel.com → Settings → API
# DEXATEL_SENDER is the alphanumeric sender name shown to recipients.
# Register and get your sender name approved in the Dexatel dashboard first.

DEXATEL_API_KEY=your_dexatel_api_key
DEXATEL_SENDER=DOT

# ==============================
# Pesepay Payment Gateway
# ==============================

PAYMENT_INTEGRATION_ID=your_pesepay_integration_id
PAYMENT_ENCRYPTION_KEY=your_pesepay_encryption_key
# USD checkout: Pesepay API expects a METHOD CODE (e.g. PZW211), not the word "card" or "ecocash".
# Copy the real code from your Pesepay dashboard. Apply to backend/.env AND frontend/.env (EXPO_PUBLIC_...).
PESEPAY_USD_PAYMENT_METHOD_CODE=PZW211

# ==============================
# ContiPay Payment Gateway
# ==============================
# Get credentials from your ContiPay merchant dashboard (https://dashboard.contipay.co.zw)
# The environment is driven by NODE_ENV:
#   development / staging → api-uat.contipay.net  (test sandbox)
#   production            → api-v2.contipay.co.zw (live)
#
# Option A — shared credentials (same key pair for both environments):
CONTIPAY_AUTH_KEY=your_contipay_auth_key
CONTIPAY_AUTH_SECRET=your_contipay_auth_secret
#
# Option B — separate credentials per environment (takes precedence over Option A):
# CONTIPAY_TEST_AUTH_KEY=your_sandbox_auth_key
# CONTIPAY_TEST_AUTH_SECRET=your_sandbox_auth_secret
# CONTIPAY_LIVE_AUTH_KEY=your_live_auth_key
# CONTIPAY_LIVE_AUTH_SECRET=your_live_auth_secret
#
CONTIPAY_MERCHANT_ID=your_numeric_merchant_id
# Force sandbox regardless of NODE_ENV. Remove or set to LIVE when going live.
CONTIPAY_ENV=DEV
# Optional overrides (same format — dashboard codes, not plain words)
# PESEPAY_USD_CARD_METHOD_CODE=
# PESEPAY_USD_ECOCASH_CODE=
# PESEPAY_USD_ONEMONEY_CODE=
# PESEPAY_USD_INNBUCKS_CODE=
# ZWL (wallet top-up / future)
PESEPAY_ZWL_ECOCASH_CODE=PZW211
PESEPAY_ZWL_ONEMONEY_CODE=PZW212

# Marketplace commission on order subtotal (default 0.20 = 20%; DoorDash/Uber-style tiers often 15–30%)
PLATFORM_COMMISSION_RATE=0.20

# Courier earns this share (default 0.8 = 80%) of max(0, customer delivery_fee − OTD fee).
COURIER_DELIVERY_FEE_SHARE=0.8
# Delivery platform/service fee withheld from courier pool (“OTD”; shown in courier apps).
OTD_PLATFORM_SERVICE_CHARGE_USD=0.99

# Public HTTPS base URL of this API (used in mobile app for resultUrl / returnUrl). Examples: ngrok, Render, Railway, Fly.io
PUBLIC_API_BASE_URL=

# Must match app.config.js scheme (default dotdeliveryontime)
APP_PAYMENT_DEEP_LINK_SCHEME=dotdeliveryontime

# ==============================
# Help & support (merchant app — GET /merchant/help)
# ==============================

# ==============================
# Google Maps (address autocomplete / reverse geocoding proxy)
# ==============================
# Create a key at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

SUPPORT_PHONE=+263771234567
SUPPORT_EMAIL=support@example.com
# Optional: WhatsApp chat link, e.g. https://wa.me/263771234567
SUPPORT_WHATSAPP_URL=
SUPPORT_HOURS=Mon–Fri 8:00–18:00

# ==============================
# Server Configuration
# ==============================

PORT=4000
NODE_ENV=development

# ==============================
# CORS (comma-separated)
# ==============================

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# ==============================
# Admin Dashboard API key
# ==============================

ADMIN_API_KEY=your_admin_api_key
